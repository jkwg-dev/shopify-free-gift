# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Shopify app (Dev Dashboard custom-distribution OAuth app; Advanced plan)
SHOPIFY_SHOP_DOMAIN=our-store.myshopify.com
# Client ID and Client secret from the Dev Dashboard app. The Client secret is the SINGLE shared
# secret for OAuth HMAC, webhook HMAC, AND App Proxy signature verification — no separate secret.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# The app's deployed base URL (Vercel production). Used for the OAuth redirect_uri + App Proxy URL.
SHOPIFY_APP_URL=https://your-app.vercel.app
# Access scopes requested at install; MUST match shopify.app.toml and the Dev Dashboard app.
# Defaults in code to read_products,write_discounts,read_discounts if unset.
SHOPIFY_SCOPES=read_products,write_discounts,read_discounts
# Pinned Admin API version; revisit at the next quarterly release (2026-07).
SHOPIFY_API_VERSION=2026-04
# Shop base currency (ISO 4217). The discount minimum-subtotal and base-currency tier thresholds
# are denominated here; /validate also evaluates in this currency when the buyer's market is base.
SHOPIFY_BASE_CURRENCY=CAD
# Online Store publication GID, for the Stage-E gift-availability check (publishedOnPublication —
# read_products only, no read_product_listings). REQUIRED: a missing/malformed value FAILS the
# /config + /validate availability path loudly (named error); it NEVER silently falls back to a
# stock-only check. This id is PER-ENVIRONMENT — dev's differs from production's. Look it up in each
# environment: publications(first:10){ nodes { id name } } -> pick "Online Store".
# Dev value: gid://shopify/Publication/157545496685
SHOPIFY_ONLINE_STORE_PUBLICATION_ID=

# NOTE: there is NO admin access token in env. The offline Admin API token is obtained via OAuth
# install and stored ENCRYPTED in the Shop row (see TOKEN_ENCRYPTION_KEY below); the app decrypts
# it per request to call the Admin API.

# Postgres (admin campaign store). Hosted dev branch — Neon / Supabase / Vercel Postgres —
# matching the deploy target; no Docker. DATABASE_URL may be a pooled connection; DIRECT_URL is
# the unpooled connection Prisma migrations use.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DIRECT_URL=postgresql://user:password@host/db?sslmode=require

# 32-byte (256-bit) key, base64-encoded, for AES-256-GCM encryption of offline access tokens at
# rest. Generate with: openssl rand -base64 32. Load from a secret manager in production.
TOKEN_ENCRYPTION_KEY=
