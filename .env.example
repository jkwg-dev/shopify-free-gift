# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Shopify Admin API (Advanced plan; custom/internal app)
SHOPIFY_SHOP_DOMAIN=our-store.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ADMIN_ACCESS_TOKEN=
# Pinned Admin API version; revisit at the next quarterly release (2026-07).
SHOPIFY_API_VERSION=2026-04

# Postgres (admin campaign store). Local dev via docker-compose (added in Phase 3).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/free_gift_engine
